{
  "name": "opencode-slack-bridge",
  "version": "0.1.0",
  "description": "Slack bridge for OpenCode - chat with your coding agent from Slack",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "tsx src/setup.ts",
    "check": "tsx src/setup.ts"
  },
  "keywords": [
    "slack",
    "opencode",
    "ai",
    "coding-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/sdk": "^1.3.13",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
