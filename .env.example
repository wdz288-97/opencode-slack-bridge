# Slack App Tokens (from api.slack.com/apps)
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_BOT_TOKEN=xoxb-your-bot-user-oauth-token

# OpenCode Server
OPENCODE_URL=http://localhost:4096

# Agent to use for prompts (must match agent name in oh-my-opencode.json)
OPENCODE_AGENT=slack-bridge

# Access Control (comma-separated user IDs, empty = allow all)
# ALLOWED_USERS=U01ABCDEF,U02GHIJKL

# Allowed channels (empty = allow all)
# ALLOWED_CHANNELS=C01ABCDEF,C02GHIJKL
